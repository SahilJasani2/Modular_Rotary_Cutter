<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_Drive" Id="{29575593-8274-429c-a355-871bac34c303}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Drive IMPLEMENTS I_Drive
VAR
    // --- The Link to TwinCAT Motion (NC) ---
    // This is the "Data Highway" between your PLC code and the NC-Task
    Axis : AXIS_REF; 

    // --- Standard PLCopen Motion Blocks ---
    fbPower     : MC_Power;
    fbReset     : MC_Reset;
    fbStop      : MC_Stop;
    fbMoveAbs   : MC_MoveAbsolute;
    fbMoveVel   : MC_MoveVelocity;
	fbHome      : MC_Home;

    // --- Internal Status Tracking ---
    bEnableCmd  : BOOL; // Linked to P_Enabled
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// 1. Always Update the Axis Status
Axis.ReadStatus();

// 2. Power Control (Torque on/off)
fbPower(
    Axis := Axis,
    Enable := bEnableCmd,
    Enable_Positive := bEnableCmd,
    Enable_Negative := bEnableCmd
);

// 3. Call the Motion Function Blocks
// Note: We call them here so they can process their internal state machines
fbReset(Axis := Axis);
fbStop(Axis := Axis);
fbMoveAbs(Axis := Axis);
fbMoveVel(Axis := Axis);
fbHome(Axis := Axis);

// =========================================================
// CORRECTED TRIGGER RESET LOGIC
// =========================================================
// The Execute signals are now only dropped once the NC block 
// finishes its operation. This ensures the FB state machines 
// complete their execution and accurately reflect P_Busy.

IF fbReset.Done OR fbReset.Error THEN
    fbReset.Execute := FALSE;
END_IF

IF fbStop.Done OR fbStop.CommandAborted OR fbStop.Error THEN
    fbStop.Execute := FALSE;
END_IF

IF fbMoveAbs.Done OR fbMoveAbs.CommandAborted OR fbMoveAbs.Error THEN
    fbMoveAbs.Execute := FALSE;
END_IF

IF fbMoveVel.CommandAborted OR fbMoveVel.Error THEN
    fbMoveVel.Execute := FALSE;
END_IF

IF fbHome.Done OR fbHome.CommandAborted OR fbHome.Error THEN
    fbHome.Execute := FALSE;
END_IF]]></ST>
    </Implementation>
    <Method Name="M_Home" Id="{7790ed11-5148-4807-a00e-287e41768cda}">
      <Declaration><![CDATA[METHOD M_Home : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Trigger a rising edge on the internal home block
// Note: We use the default homing mode configured in the TwinCAT NC Axis
fbHome.bCalibrationCam := FALSE; 
fbHome.Execute := TRUE;

M_Home := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_MoveAbs" Id="{91be8eab-f779-49c3-9c91-e8161a59ed82}">
      <Declaration><![CDATA[METHOD M_MoveAbs : BOOL
VAR_INPUT
	(* Target position in mm or degrees*)
	fPosition	: LREAL;
	(* Speed for this move*)
	fVelocity	: LREAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Trigger a rising edge on the internal motion block
fbMoveAbs.Position := fPosition;
fbMoveAbs.Velocity := fVelocity;
fbMoveAbs.Execute := TRUE; 

M_MoveAbs := TRUE; // Return TRUE to show the command was received]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_MoveVel" Id="{37e662dd-1514-4118-a818-f288d90d7c84}">
      <Declaration><![CDATA[METHOD M_MoveVel : BOOL
VAR_INPUT
	(* Speed in mm/s or RPM*)
	fVelocity	: LREAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[fbMoveVel.Velocity := fVelocity;
fbMoveVel.Direction := MC_Positive_Direction;
fbMoveVel.Execute := TRUE;

M_MoveVel := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Reset" Id="{b7138b05-71aa-42a5-bcb7-54cd0cd5d5d0}">
      <Declaration><![CDATA[METHOD M_Reset : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[fbReset.Execute := TRUE; M_Reset := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Stop" Id="{a8aa22d7-69f3-4b58-8bbe-8959b5116ba7}">
      <Declaration><![CDATA[METHOD M_Stop : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[fbStop.Execute := TRUE; M_Stop := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Property Name="P_Axis" Id="{c438ebb6-f4fa-4896-b4fc-45b79fc5096e}">
      <Declaration><![CDATA[PROPERTY P_Axis : REFERENCE TO AXIS_REF]]></Declaration>
      <Get Name="Get" Id="{971a64fc-7619-44e1-b200-2ade4597c9b2}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_Axis REF= Axis; // This creates a 'link' to the real Axis variable]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_Busy" Id="{0954bfd9-2a2f-442b-88a7-0fc7aa654616}">
      <Declaration><![CDATA[PROPERTY P_Busy : BOOL
]]></Declaration>
      <Get Name="Get" Id="{af39002d-3e39-450d-9298-2d3614d5dde1}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[// The axis is busy if it is physically moving or if a move block is still active
P_Busy := Axis.Status.Moving OR fbMoveAbs.Busy OR fbMoveVel.Busy OR fbHome.Busy;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_Enabled" Id="{aa86077e-a730-425c-9d71-e45f00711c2b}">
      <Declaration><![CDATA[PROPERTY P_Enabled : BOOL
]]></Declaration>
      <Get Name="Get" Id="{92730983-4549-44bf-8946-dcdf46ccfe10}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_Enabled := bEnableCmd;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{a6e6e813-1d0d-42b7-b058-ad03723ae751}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[bEnableCmd := P_Enabled;]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Property Name="P_Error" Id="{dc88c766-3499-41ab-b41f-3c6f5290d649}">
      <Declaration><![CDATA[PROPERTY P_Error : BOOL
]]></Declaration>
      <Get Name="Get" Id="{a36b31b8-1fee-448b-b160-4c3cf7dd54df}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_Error := Axis.Status.Error;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_Ready" Id="{614d4749-6d6c-42bf-a79f-dfd89216bbcd}">
      <Declaration><![CDATA[PROPERTY P_Ready : BOOL
]]></Declaration>
      <Get Name="Get" Id="{9697a46b-6c06-4d27-8b82-b857d1608699}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_Ready := Axis.Status.Operational;]]></ST>
        </Implementation>
      </Get>
    </Property>
  </POU>
</TcPlcObject>