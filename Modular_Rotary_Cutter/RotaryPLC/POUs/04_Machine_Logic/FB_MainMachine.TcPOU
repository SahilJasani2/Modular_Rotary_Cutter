<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_MainMachine" Id="{7d03d295-f101-4685-8cbf-a1d2f35ed8c9}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_MainMachine
VAR
    // --- The Physical Modules ---
    InfeedConveyor  : FB_InfeedConveyor;
    RotaryKnife     : FB_RotaryKnife;
    
    // --- The Virtual Motors ---
    ConveyorMotor   : FB_Drive;
    KnifeMotor      : FB_Drive;

    // --- Concrete Hardware Instances for Simulation ---
    fbProductSensor : FB_DigitalSensor;

    // --- Edge/IoT Telemetry ---
    EdgeGateway     : FB_Telemetry;

    // --- State Machine Tracking ---
    eState          : E_MachineState := E_MachineState.STOPPED;

    // --- Operator Commands ---
    bCmdStart       : BOOL;
    bCmdStop        : BOOL;
    bCmdReset       : BOOL;

    // --- Industrial Diagnostics (Alarms) ---
    fbEventLogger      : FB_TcEventLogger;
    fbAlarm            : FB_TcAlarm;
    bAlarmsInitialized : BOOL; // Flag to run setup code only once
    tonSensorJam       : TON;  // Detects if material is stuck under the sensor
    
    // --- Safety Interface ---
    bSafetyOk          : BOOL; // Locally mapped safety signal from TwinSAFE
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// =========================================================
// 0. SAFETY INTERLOCK (Highest Priority)
// =========================================================
// Link the global safety signal to our local variable
bSafetyOk := GVL_Safety.bSafetyOk;

// Force EMERGENCY_STOP state immediately if safety is lost
IF NOT bSafetyOk THEN
    eState := E_MachineState.EMERGENCY_STOP;
END_IF

// =========================================================
// 1. HARDWARE LINKING
// =========================================================
InfeedConveyor.iProductCam := fbProductSensor;
InfeedConveyor.iMotor := ConveyorMotor;
RotaryKnife.iMotor    := KnifeMotor;

// =========================================================
// 2. THE MAIN STATE MACHINE
// =========================================================
CASE eState OF

    E_MachineState.STOPPED:
        // Only allow start if Safety is OK
        IF bCmdStart AND bSafetyOk THEN
            bCmdStart := FALSE;
            eState := E_MachineState.STARTING;
        END_IF

    E_MachineState.STARTING:
        eState := E_MachineState.EXECUTE;

    E_MachineState.EXECUTE:
        RotaryKnife.bEnable := TRUE;

        // Ninja Chop Logic
        IF fbProductSensor.P_RisingEdge THEN
            RotaryKnife.bSyncCommand := TRUE;
        END_IF
        
        IF fbProductSensor.P_FallingEdge THEN
            RotaryKnife.bSyncCommand := FALSE;
        END_IF

        IF bCmdStop THEN
            bCmdStop := FALSE;
            RotaryKnife.bEnable := FALSE;
            RotaryKnife.bSyncCommand := FALSE;
            eState := E_MachineState.STOPPING;
        END_IF

    E_MachineState.STOPPING:
        eState := E_MachineState.STOPPED;

    E_MachineState.ERROR:
        // Only allow Reset if Safety is OK
        IF bCmdReset AND bSafetyOk THEN
            bCmdReset := FALSE;
            fbAlarm.Clear(0, TRUE);
            eState := E_MachineState.STOPPED;
        END_IF

    E_MachineState.EMERGENCY_STOP:
        // KILL ACTUATORS
        RotaryKnife.bEnable := FALSE;
        RotaryKnife.bSyncCommand := FALSE;
        // ConveyorMotor.bEnable is not required/supported by FB_Drive
        
        // Recovery: Exit only if Safety is restored AND operator presses Reset
        IF bSafetyOk AND bCmdReset THEN
            bCmdReset := FALSE;
            eState := E_MachineState.STOPPED;
        END_IF

END_CASE

// =========================================================
// 3. INDUSTRIAL DIAGNOSTICS (ALARM LOGIC)
// =========================================================
IF NOT bAlarmsInitialized THEN
    fbAlarm.CreateEx(TC_Events.MachineAlarms.ConveyorSensorJam, TRUE, 0);
    bAlarmsInitialized := TRUE;
END_IF

tonSensorJam(IN := (fbProductSensor.bRawInput AND eState = E_MachineState.EXECUTE), PT := T#5S);

IF tonSensorJam.Q THEN
    fbAlarm.Raise(0);
    eState := E_MachineState.ERROR;
END_IF

// =========================================================
// 4. ALWAYS CALL THE MODULES AND MOTORS
// =========================================================
fbProductSensor();
ConveyorMotor();
KnifeMotor();
InfeedConveyor();
RotaryKnife();

// =========================================================
// 5. TELEMETRY & CLOUD SYNC
// =========================================================
EdgeGateway(eCurrentState := eState);]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>