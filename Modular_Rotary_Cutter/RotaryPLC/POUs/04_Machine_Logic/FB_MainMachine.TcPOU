<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_MainMachine" Id="{7d03d295-f101-4685-8cbf-a1d2f35ed8c9}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_MainMachine
VAR
    // --- The Physical Modules ---
    InfeedConveyor  : FB_InfeedConveyor;
    RotaryKnife     : FB_RotaryKnife;
    
    // --- The Virtual Motors ---
    ConveyorMotor   : FB_Drive;
    KnifeMotor      : FB_Drive;

    // --- Concrete Hardware Instances for Simulation ---
    fbProductSensor : FB_DigitalSensor;

    // --- Edge/IoT Telemetry ---
    EdgeGateway     : FB_Telemetry;

    // --- State Machine Tracking ---
    eState          : E_MachineState := E_MachineState.STOPPED;

    // --- Operator Commands ---
    bCmdStart       : BOOL;
    bCmdStop        : BOOL;
    bCmdReset       : BOOL;

    // --- Industrial Diagnostics (Alarms) ---
    fbEventLogger      : FB_TcEventLogger;
    fbAlarm            : FB_TcAlarm;
    bAlarmsInitialized : BOOL; // Flag to run setup code only once
    tonSensorJam       : TON;  // Detects if material is stuck under the sensor
    
    // --- Safety Interface ---
    bSafetyOk          : BOOL; // Locally mapped safety signal from TwinSAFE
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// =========================================================
// 0. SAFETY MONITORING
// =========================================================
bSafetyOk := GVL_Safety.bSafetyOk;

// If safety drops, force the state machine into the ABORT sequence immediately.
IF NOT bSafetyOk AND eState <> E_MachineState.ABORTING AND eState <> E_MachineState.ABORTED THEN
    eState := E_MachineState.ABORTING;
END_IF

// =========================================================
// 1. HARDWARE LINKING
// =========================================================
InfeedConveyor.iProductCam := fbProductSensor;
InfeedConveyor.iMotor      := ConveyorMotor;
RotaryKnife.iMotor         := KnifeMotor;

// =========================================================
// 2. THE PACKML STATE MACHINE
// =========================================================
CASE eState OF

    E_MachineState.UNDEFINED:
        eState := E_MachineState.STOPPED;

    // ---------------------------------------------------------
    // NORMAL OPERATIONS
    // ---------------------------------------------------------
    E_MachineState.STOPPED:
        IF bCmdStart AND bSafetyOk THEN
            bCmdStart := FALSE;
            eState := E_MachineState.STARTING;
        END_IF

    E_MachineState.STARTING:
        // Trigger the homing routine we built in Phase 1
        RotaryKnife.bHomeCommand := TRUE;
        
        // Wait for the knife to finish homing before moving to EXECUTE
        // (Assuming the motor drops P_Busy when homing is complete)
        IF NOT RotaryKnife.iMotor.P_Busy THEN 
            RotaryKnife.bHomeCommand := FALSE;
            eState := E_MachineState.EXECUTE;
        END_IF

    E_MachineState.EXECUTE:
        RotaryKnife.bEnable := TRUE;
        // InfeedConveyor.bEnable := TRUE; // We will add this to the conveyor block next!

        // Ninja Chop Logic
        IF fbProductSensor.P_RisingEdge THEN
            RotaryKnife.bSyncCommand := TRUE;
        END_IF
        
        IF fbProductSensor.P_FallingEdge THEN
            RotaryKnife.bSyncCommand := FALSE;
        END_IF

        IF bCmdStop THEN
            bCmdStop := FALSE;
            eState := E_MachineState.HOLDING;
        END_IF

    // ---------------------------------------------------------
    // PAUSING (Non-critical stops)
    // ---------------------------------------------------------
    E_MachineState.HOLDING:
        RotaryKnife.bSyncCommand := FALSE;
        eState := E_MachineState.HELD;

    E_MachineState.HELD:
        IF bCmdStart AND bSafetyOk THEN
            bCmdStart := FALSE;
            eState := E_MachineState.UNHOLDING;
        END_IF

    E_MachineState.UNHOLDING:
        eState := E_MachineState.EXECUTE;

    // ---------------------------------------------------------
    // FAULTS & SAFETY 
    // ---------------------------------------------------------
    E_MachineState.ABORTING:
        // Drop logical commands
        RotaryKnife.bSyncCommand := FALSE;
        eState := E_MachineState.ABORTED;

    E_MachineState.ABORTED:
        // Wait for physical safety to return AND operator to press Reset
        IF bSafetyOk AND bCmdReset THEN
            bCmdReset := FALSE;
            eState := E_MachineState.CLEARING;
        END_IF

    E_MachineState.CLEARING:
        // Require explicit Acknowledge (Confirm) before clearing
        fbAlarm.Confirm(0);
        fbAlarm.Clear(0, TRUE);
        eState := E_MachineState.STOPPED;

    // ---------------------------------------------------------
    // AUXILIARY MODES
    // ---------------------------------------------------------
    E_MachineState.CLEANING:
        IF bCmdStop THEN
            bCmdStop := FALSE;
            eState := E_MachineState.STOPPED;
        END_IF

END_CASE

// =========================================================
// 3. INDUSTRIAL DIAGNOSTICS (ALARM LOGIC)
// =========================================================
IF NOT bAlarmsInitialized THEN
    fbAlarm.CreateEx(TC_Events.MachineAlarms.ConveyorSensorJam, TRUE, 0);
    bAlarmsInitialized := TRUE;
END_IF

tonSensorJam(IN := (fbProductSensor.bRawInput AND eState = E_MachineState.EXECUTE), PT := T#5S);

IF tonSensorJam.Q THEN
    fbAlarm.Raise(0);
    eState := E_MachineState.ABORTING; // Send machine to fault state
END_IF

// =========================================================
// 4. HARDWARE SAFETY MASK (Absolute Override - STEP 12)
// =========================================================
// No matter what the State Machine above is doing, if safety is lost, 
// or we are in a fault state, physically drop actuator power.
IF NOT bSafetyOk OR eState = E_MachineState.ABORTING OR eState = E_MachineState.ABORTED THEN
    RotaryKnife.bEnable := FALSE;
    RotaryKnife.bSyncCommand := FALSE;
    // InfeedConveyor.bEnable := FALSE; // Will be uncommented in Step 13
END_IF

// =========================================================
// 5. ALWAYS CALL THE MODULES AND MOTORS
// =========================================================
fbProductSensor();
ConveyorMotor();
KnifeMotor();
InfeedConveyor();
RotaryKnife();

// =========================================================
// 6. TELEMETRY & CLOUD SYNC
// =========================================================
EdgeGateway(eCurrentState := eState);]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>