<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_RotaryKnife" Id="{48fb6193-f953-456c-9937-b4916335cb68}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_RotaryKnife
VAR_INPUT
    // --- Hardware Link ---
    iMotor          : I_Drive;
    
    // --- Commands from Main Machine ---
    bEnable         : BOOL;
    bSyncCommand    : BOOL;
    bHomeCommand    : BOOL;  // <--- NEW: Request to find Zero position

    // --- NEW: Machine Parameters ---
    fKnifeDiameter  : LREAL := 100.0; // Moved from VAR to VAR_INPUT
END_VAR
VAR
    // --- Master Reference ---
    pMasterAxis     : REFERENCE TO AXIS_REF;
    
    // --- Motion Control Blocks ---
    fbGearIn        : MC_GearIn;
    fbGearOut       : MC_GearOut;
    rtHome          : R_TRIG; // <--- NEW: Rising edge trigger for homing
    
    // --- Configuration ---
    fGearRatio      : LREAL := 1.0;
    
    // --- Status ---
    bIsSynchronized : BOOL;
    bError          : BOOL;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// 1. Safety Check: Only run if a motor has been assigned
IF iMotor <> 0 THEN
    
    // 2. Control the Motor Power
    iMotor.P_Enabled := bEnable;
    bError := iMotor.P_Error;

    // =========================================================
    // 3. NEW: HOMING SEQUENCE
    // =========================================================
    rtHome(CLK := bHomeCommand);
    IF rtHome.Q THEN
        iMotor.M_Home(); // Trigger the hardware wrapper homing method!
    END_IF

    // =========================================================
    // 4. ELECTRONIC GEARING (Synchronization)
    // =========================================================
    IF __ISVALIDREF(pMasterAxis) THEN
        
        // Command to Lock the Knife to the Conveyor
        fbGearIn(
            Master           := pMasterAxis,
            Slave            := iMotor.P_Axis, 
            Execute          := bSyncCommand,
            RatioNumerator   := 1,
            RatioDenominator := 1,
            Acceleration     := 1000,
            Deceleration     := 1000
        );
        
        bIsSynchronized := fbGearIn.InGear;
        
        // Command to Unlock (Stop following)
        fbGearOut(
            Slave            := iMotor.P_Axis,
            Execute          := NOT bSyncCommand AND bIsSynchronized
        );
    END_IF
    
END_IF]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>